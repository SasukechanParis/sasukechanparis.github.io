rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // オーナーは自分の配下すべてに無制限アクセス
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // スタッフ判定: オーナーが作成した meta/staffEmails のリストで照合
    function isStaffOf(ownerUid) {
      let indexDoc = /databases/$(database)/documents/users/$(ownerUid)/meta/staffEmails;
      return request.auth != null
        && exists(indexDoc)
        && get(indexDoc).data.emails.hasAny([request.auth.token.email]);
    }

    // collectionGroup: スタッフが自分のドキュメントを検索するため
    match /{path=**}/staffs/{staffDocId} {
      allow read: if request.auth != null
                  && resource.data.email == request.auth.token.email;
    }

    // スタッフ → オーナーの設定（言語・通貨・スタジオ名等）
    match /users/{ownerUid}/meta/state {
      allow read: if isStaffOf(ownerUid);
    }

    // スタッフ → オーナーの顧客データ（主パス）
    match /users/{ownerUid}/projects/{clientId} {
      allow read, write: if isStaffOf(ownerUid);
    }

    // スタッフ → オーナーの顧客データ（レガシーパス）
    match /users/{ownerUid}/clients/{clientId} {
      allow read, write: if isStaffOf(ownerUid);
    }

    // スタッフ → スタッフ一覧（チームメンバー表示用）
    match /users/{ownerUid}/staffs/{staffDocId} {
      allow read: if isStaffOf(ownerUid);
    }

  }
}
